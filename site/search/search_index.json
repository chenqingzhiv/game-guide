{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ud83c\udf3e \u79cd\u7530\u6e38\u620f\u653b\u7565","text":"<p>\u6b22\u8fce\u6765\u5230 FarmingGames.Help \u2014 \u79cd\u7530/\u519c\u573a/\u6a21\u62df\u7ecf\u8425\u6e38\u620f\u7684\u4e00\u7ad9\u5f0f\u653b\u7565\u6570\u636e\u5e93\uff01</p>"},{"location":"#_2","title":"\ud83c\udfae \u70ed\u95e8\u6e38\u620f","text":"<ul> <li> <p>\ud83c\udf3f \u661f\u9732\u8c37\u7269\u8bed Stardew Valley</p> <ul> <li>\u5168\u4f5c\u7269\u6536\u76ca\u8868 \ud83d\udcca</li> <li>\u5168\u89d2\u8272\u597d\u611f\u653b\u7565 \ud83d\udc95</li> <li>\u77ff\u5c71\u5c42\u6570\u6307\u5357 \u26cf\ufe0f</li> <li>\u5b63\u8282\u79cd\u690d\u65e5\u5386 \ud83d\udcc5</li> <li>\u2192 \u8fdb\u5165\u6570\u636e\u5e93</li> </ul> </li> <li> <p>\ud83d\udc04 \u7267\u573a\u7269\u8bed Harvest Moon</p> <ul> <li>\u7cfb\u5217\u5168\u4f5c\u54c1\u5bf9\u6bd4</li> <li>\u4f5c\u7269/\u52a8\u7269\u517b\u6210\u6307\u5357</li> <li>\u7ed3\u5a5a\u5019\u9009\u4eba\u4e00\u89c8</li> <li>\u9690\u85cf\u4e8b\u4ef6\u89e6\u53d1\u6761\u4ef6</li> <li>\u2192 \u8fdb\u5165\u6570\u636e\u5e93</li> </ul> </li> <li> <p>\ud83d\ude9c Farming Simulator</p> <ul> <li>\u5168\u673a\u578b\u53c2\u6570\u5bf9\u6bd4</li> <li>\u8015\u5730/\u64ad\u79cd/\u6536\u5272\u6d41\u7a0b</li> <li>\u517b\u6b96\u573a\u7ecf\u8425\u6307\u5357</li> <li>\u7ecf\u6d4e\u6a21\u5f0f\u8be6\u89e3</li> <li>\u2192 \u8fdb\u5165\u6570\u636e\u5e93</li> </ul> </li> </ul>"},{"location":"#_3","title":"\ud83d\udcca \u70ed\u95e8\u6570\u636e\u9875","text":"\u9875\u9762 \u7528\u9014 \u661f\u9732\u8c37\u7269\u8bed\u5168\u4f5c\u7269\u6536\u76ca\u8868 \u79cd\u4ec0\u4e48\u6700\u8d5a\u94b1\uff1f \u7267\u573a\u7269\u8bed\u5168\u7ed3\u5a5a\u5bf9\u8c61\u4e00\u89c8 \u8c01\u6700\u597d\u8ffd\uff1f Farming Simulator\u5168\u673a\u578b\u5bf9\u6bd4 \u54ea\u53f0\u62d6\u62c