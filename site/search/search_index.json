7267\u573a\u7269\u8bed\u7cfb\u5217 \u5168\u5e73\u53f0 \u519c\u573a\u6a21\u62df+\u751f\u6d3b \u2705 \u5df2\u6536\u5f55 Farming Simulator PC/NS/PS/Xbox \u771f\u5b9e\u519c\u573a\u6a21\u62df \u2705 \u5df2\u6536\u5f55 \u66f4\u591a\u6e38\u620f\u5f85\u6dfb\u52a0... \ud83d\udea7 \u65bd\u5de5\u4e2d"},{"location":"database/#_3","title":"\ud83d\udccb \u6570\u636e\u5e93\u7ed3\u6784","text":"<p>\u6bcf\u4e2a\u6e38\u620f\u5305\u542b\uff1a - \u57fa\u7840\u6570\u636e \u2014 \u4f5c\u7269/\u52a8\u7269/\u5de5\u5177\u53c2\u6570 - \u653b\u7565\u6570\u636e \u2014 \u8d5a\u94b1\u8def\u7ebf/\u6548\u7387\u5bf9\u6bd4 - \u53c2\u8003\u6570\u636e \u2014 \u5b63\u8282\u65e5\u5386/\u597d\u611f\u8868/\u5408\u6210\u8868</p>"},{"location":"database/#_4","title":"\ud83e\udd1d \u8d21\u732e","text":"<p>\u672c\u6570\u636e\u5e93\u7531\u73a9\u5bb6\u793e\u533a\u7ef4\u62a4\uff0c\u6b22\u8fce\u8865\u5145\u6570\u636e\uff01</p>"},{"location":"database/farming-simulator/","title":"Farming Simulator","text":"<p>\u7531 Giants Software \u5f00\u53d1\u7684\u771f\u5b9e\u519c\u573a\u6a21\u62df\u7cfb\u5217\u3002</p>"},{"location":"database/farming-simulator/#_1","title":"\ud83d\ude9c \u7cfb\u5217\u7248\u672c","text":"\u7248\u672c \u53d1\u552e\u5e74 \u65b0\u589e\u7279\u8272 FS19 2018 3\u79cd\u519c\u4e1a\u7c7b\u578b FS22 2021 \u751f\u4ea7\u94fe\u7cfb\u7edf\u3001\u65b0\u4f5c\u7269 FS25 2024 \u8de8\u5e73\u53f0\u8054\u673a\u3001\u5b63\u8282\u7cfb\u7edf\u4f18\u5316"},{"location":"database/farming-simulator/#fs22","title":"\ud83c\udf31 \u6700\u8d5a\u94b1\u7684\u4f5c\u7269\uff08FS22\uff09","text":"\u4f5c\u7269 \u79cd\u690d\u5b63\u8282 \u552e\u4ef7/\u5343\u5347 \u6536\u76ca\u6392\u540d \u8461\u8404 \ud83c\udf47 \u590f\u5b63 \u9ad8 1 \u6a44\u6984 \ud83e\uded2 \u6625\u5b63 \u9ad8 2 \u68c9\u82b1 \ud83c\udf3f \u6625\u5b63 \u4e2d\u9ad8 3 \u7389\u7c73 \ud83c\udf3d \u6625\u5b63 \u4e2d 4 \u5c0f\u9ea6 \ud83c\udf3e \u79cb\u5b63 \u4f4e - <p>\ud83d\udca1 \u6280\u5de7\uff1a\u8461\u8404\u548c\u6a44\u6984\u9700\u8981\u4e13\u7528\u8bbe\u5907\uff0c\u521d\u671f\u6295\u5165\u5927\u4f46\u957f\u671f\u6536\u76ca\u6700\u9ad8\u3002</p>"},{"location":"database/farming-simulator/#_2","title":"\ud83d\udc04 \u517b\u6b96\u6536\u76ca\u5bf9\u6bd4","text":"\u52a8\u7269 \u521d\u59cb\u6295\u5165 \u6bcf\u65e5\u6536\u76ca \u56de\u672c\u5468\u671f \u9e21 \ud83d\udc14 \u4f4e \u4f4e \u5feb \u7f8a \ud83d\udc11 \u4e2d \u4e2d \u4e2d \u725b \ud83d\udc04 \u9ad8 \u9ad8 \u6162 \u9a6c \ud83d\udc0e \u9ad8 - \u88c5\u9970\u7528\u9014"},{"location":"database/harvest-moon/","title":"\u7267\u573a\u7269\u8bed Harvest Moon","text":"<p>\u7ecf\u5178\u519c\u573a\u751f\u6d3b\u6a21\u62df\u7cfb\u5217\uff0c\u7531 Marvelous\uff08\u539f Victor Interactive\uff09\u5f00\u53d1\u3002</p>"},{"location":"database/harvest-moon/#_1","title":"\ud83d\udccb \u7cfb\u5217\u4f5c\u54c1\u4e00\u89c8","text":"\u4f5c\u54c1 \u5e73\u53f0 \u53d1\u552e\u5e74 \u7279\u8272 \u7267\u573a\u7269\u8bed\uff1a\u77ff\u77f3\u9547\u7684\u4f19\u4f34\u4eec GBA 2003 \u7cfb\u5217\u5dc5\u5cf0\u4e4b\u4f5c \u7267\u573a\u7269\u8bed\uff1a\u7f8e\u4e3d\u4eba\u751f GC/PS2 2003 \u513f\u5b50\u6210\u957f\u7cfb\u7edf \u7267\u573a\u7269\u8bed\uff1a\u53cc\u5b50\u6751 NDS 2010 \u53cc\u6751\u9009\u62e9\u673a\u5236 \u7267\u573a\u7269\u8bed\uff1a\u8fde\u63a5\u65b0\u5929\u5730 3DS 2014 \u8d38\u6613\u7cfb\u7edf \u7267\u573a\u7269\u8bed\uff1a\u6a44\u6984\u9547\u4e0e\u5e0c\u671b\u7684\u5927\u5730 NS 2021 \u7cfb\u5217\u6700\u65b0\u4f5c"},{"location":"database/harvest-moon/#_2","title":"\ud83c\udf3e \u8d5a\u94b1\u57fa\u7840\u8def\u7ebf","text":"<ol> <li>\u7b2c\u4e00\u5e74\u6625\uff1a\u79cd\u829c\u83c1\u6512\u94b1\uff0c\u9493\u9c7c\u8865\u5145\u6536\u5165</li> <li>\u7b2c\u4e00\u5e74\u590f\uff1a\u79cd\u83e0\u841d/\u7389\u7c73\uff0c\u6269\u5efa\u9e21\u820d</li> <li>\u7b2c\u4e00\u5e74\u79cb\uff1a\u79cd\u5730\u74dc/\u7ea2\u85af\uff0c\u5347\u7ea7\u5de5\u5177</li> <li>\u7b2c\u4e00\u5e74\u51ac\uff1a\u4e0b\u77ff\u6536\u96c6\u77ff\u77f3</li> <li>\u7b2c\u4e8c\u5e74\uff1a\u5165\u624b\u5976\u725b \u2192 \u5976\u916a \u2192 \u7a33\u5b9a\u6536\u5165</li> </ol>"},{"location":"database/harvest-moon/#_3","title":"\ud83d\udc8d \u7ed3\u5a5a\u6761\u4ef6","text":"<ul> <li>\u7ea2\u5fc3\u4e8b\u4ef6\u89e6\u53d1\uff084/6/8\u5fc3\uff09</li> <li>\u8d60\u9001\u9752\u4e4b\u7fbd\u6bdb</li> <li>\u6559\u5802\u4e3e\u529e\u5a5a\u793c</li> <li>\u5a5a\u540e\u914d\u5076\u5e2e\u5fd9\u5e72\u6d3b</li> </ul> <p>\ud83d\udca1 \u6280\u5de7\uff1a\u6bcf\u5929\u5bf9\u8bdd+\u9001\u793c\u7269\uff0c\u751f\u65e5\u9001\u6700\u7231\u793c\u7269\u597d\u611f\u7ffb\u500d\u3002</p>"},{"location":"database/stardew-valley/","title":"\u661f\u9732\u8c37\u7269\u8bed Stardew Valley","text":"<p>\u7531 Eric Barone\uff08ConcernedApe\uff09\u5f00\u53d1\u7684\u7ecf\u5178\u519c\u573a\u6a21\u62df\u6e38\u620f\u3002</p>"},{"location":"database/stardew-valley/#_1","title":"\u23f1\ufe0f \u5feb\u901f\u5165\u95e8","text":"<ul> <li>\u5b63\u8282\uff1a\u6625\u5b63 \u2192 \u590f\u5b63 \u2192 \u79cb\u5b63 \u2192 \u51ac\u5b63\uff0828\u5929/\u5b63\uff09</li> <li>\u8d5a\u94b1\u6838\u5fc3\uff1a\u521d\u671f\u9493\u9c7c \u2192 \u4e2d\u671f\u917f\u9152 \u2192 \u540e\u671f\u4e0a\u53e4\u6c34\u679c</li> <li>\u597d\u611f\u5ea6\uff1a\u5bf9\u8bdd\uff08+20\uff09\u2192 \u9001\u793c\uff08+45~+80\uff09\u2192 \u7ed3\u5a5a\uff08\u9700\u898110\u5fc3\uff09</li> </ul>"},{"location":"database/stardew-valley/#_2","title":"\ud83c\udf31 \u6625\u5b63\u4f5c\u7269\u6536\u76ca\u8868","text":"\u4f5c\u7269 \u79cd\u5b50\u4ef7 \u6210\u719f \u518d\u751f\u957f \u5355\u6b21\u6536\u76ca \u65e5\u6536\u76ca \u8349\u8393 \ud83c\udf53 100g 8\u5929 4\u5929 120g 20.8g \u84dd\u7235 30g 7\u5929 5\u5929 50g 7.1g \u571f\u8c46 50g 6\u5929 - 80g 5.0g \u9632\u98ce\u8349 20g 4\u5929 - 35g 3.75g <p>\ud83d\udcdd \u63d0\u793a\uff1a\u6625\u5b63\u7b2c\u4e00\u5e74\u5efa\u8bae\u591a\u79cd\u9632\u98ce\u8349\u6512\u94b1\uff0c\u590f\u5b63\u524d\u6362\u84dd\u8393/\u5564\u9152\u82b1\u3002</p>"},{"location":"database/stardew-valley/#_3","title":"\ud83d\udc95 \u7ed3\u5a5a\u5019\u9009\u4eba","text":"\u89d2\u8272 \u6700\u7231\u793c\u7269 \u751f\u65e5 \u963f\u6bd4\u76d6\u5c14 \u7d2b\u6c34\u6676/\u5357\u74dc \u79cb\u5b6313\u65e5 \u827e\u5229\u6b27\u7279 \u8783\u87f9\u86cb\u7cd5/\u77f3\u69b4 \u79cb\u5b635\u65e5 \u54c8\u7ef4 \u5496\u5561/\u814c\u83dc \u51ac\u5b6314\u65e5 \u585e\u5df4\u65af\u8482\u5b89 \u6cea\u6676/\u751f\u9c7c\u7247 \u51ac\u5b6310\u65e5"},{"location":"database/stardew-valley/#_4","title":"\u26cf\ufe0f \u77ff\u5c71\u5c42\u6570\u6307\u5357","text":"\u5c42\u6570 \u91cd\u8981\u4ea7\u51fa 1-39 \u94dc\u77ff\u3001\u77f3\u82f1 40-79 \u94c1\u77ff\u3001\u51b0\u51bb\u6676\u7403 80-119 \u91d1\u77ff\u3001\u5ca9\u6d46\u6676\u7403 120 \u9ab7\u9ac5\u94a5\u5319 \ud83d\udddd\ufe0f <p>\ud83d\udca1 \u6280\u5de7\uff1a\u4e0b\u77ff\u524d\u5403+\u901f\u5ea6\u98df\u7269\uff0c\u5e26\u8db3\u70b8\u5f39\uff0c\u76f4\u5954\u4e0b\u4e00\u5c42\u697c\u68af\u3002</p>"},{"location":"guides/","title":"\u653b\u7565\u6307\u5357","text":"<p>\u79cd\u7530\u6e38\u620f\u901a\u7528\u6280\u5de7\u6c47\u603b\u3002</p>"},{"location":"guides/#_2","title":"\ud83d\udd30 \u65b0\u624b\u5165\u95e8","text":"<ol> <li>\u5148\u770b\u653b\u7565\u518d\u52a8\u624b \u2014 \u4e86\u89e3\u4f5c\u7269\u6536\u76ca\u518d\u79cd\u5730</li> <li>\u6512\u94b1\u4f18\u5148\u4e8e\u5347\u7ea7 \u2014 \u7b2c\u4e00\u5e74\u5148\u8d5a\u591f\u672c\u91d1</li> <li>\u9493\u9c7c\u662f\u524d\u671f\u6700\u4f73\u6536\u5165 \u2014 \u5927\u90e8\u5206\u519c\u573a\u6e38\u620f\u524d\u671f\u9493\u9c7c\u6700\u8d5a\u94b1</li> <li>\u4e0d\u8981\u6269\u5efa\u592a\u5feb \u2014 \u5de5\u5177\u5347\u7ea7\u6bd4\u4e70\u65b0\u5730\u5212\u7b97</li> </ol>"},{"location":"guides/#_3","title":"\ud83d\udcb0 \u901a\u7528\u8d5a\u94b1\u516c\u5f0f","text":"<pre><code>\u65e5\u6536\u76ca = \uff08\u552e\u4ef7 - \u79cd\u5b50\u6210\u672c\uff09\u00f7 \u751f\u957f\u5929\u6570\n</code></pre>"},{"location":"guides/#_4","title":"\u9002\u7528\u6e38\u620f","text":"<ul> <li>\u2705 \u661f\u9732\u8c37\u7269\u8bed</li> <li>\u2705 \u7267\u573a\u7269\u8bed</li> <li>\u2705 Farming Simulator</li> <li>\u2705 \u7b26\u6587\u5de5\u623f</li> <li>\u2705 \u6c99\u77f3\u9547\u65f6\u5149</li> </ul>"},{"location":"guides/#_5","title":"\ud83d\udd27 \u6548\u7387\u5de5\u5177\u63a8\u8350","text":"\u5de5\u5177 \u7528\u9014 \u6d12\u6c34\u5668 \u81ea\u52a8\u6d47\u6c34\uff0c\u89e3\u653e\u53cc\u624b \u81ea\u52a8\u91c7\u96c6\u5668 \u81ea\u52a8\u6536\u9e21\u86cb/\u725b\u5976 \u9ad8\u7ea7\u9c7c\u7aff \u9493\u5927\u9c7c/\u5b9d\u7269"},{"location":"guides/#_6","title":"\ud83d\udcda \u5e38\u89c1\u95ee\u9898","text":"<p>Q: \u7b2c\u4e00\u5e74\u51ac\u5929\u5e72\u4ec0\u4e48\uff1f A: \u4e0b\u77ff\u3001\u9493\u9c7c\u3001\u6574\u7406\u519c\u573a\u3001\u5347\u7ea7\u5de5\u5177\u3001\u5237\u597d\u611f\u5ea6\u3002</p> <p>Q: \u4ec0\u4e48\u65f6\u5019\u8be5\u5347\u7ea7\u5de5\u5177\uff1f A: \u5f53\u6d47\u6c34/\u780d\u6811\u5360\u7528\u8d85\u8fc7\u534a\u5929\u65f6\u95f4\u65f6\u3002</p> <p>Q: \u52a8\u7269\u503c\u5f97\u517b\u5417\uff1f A: \u524d\u671f\u4e0d\u63a8\u8350\uff08\u6295\u5165\u5927\u56de\u672c\u6162\uff09\uff0c\u4e2d\u671f\u7a33\u5b9a\u6536\u5165\u540e\u53ef\u4ee5\u8003\u8651\u3002</p>"},{"location":"news/","title":"\u66f4\u65b0\u65e5\u5fd7","text":""},{"location":"news/#2026-06","title":"2026-06","text":"<ul> <li>\ud83c\udf89 \u7f51\u7ad9\u4e0a\u7ebf \u2014 \u79cd\u7530\u6e38\u620f\u6570\u636e\u5e93\u6b63\u5f0f\u5f00\u653e\uff01</li> <li>\u5df2\u6536\u5f55\uff1a\u661f\u9732\u8c37\u7269\u8bed\u3001\u7267\u573a\u7269\u8bed\u3001Farming Simulator</li> <li>\u66f4\u591a\u5185\u5bb9\u6301\u7eed\u66f4\u65b0\u4e2d...</li> </ul>"}]}